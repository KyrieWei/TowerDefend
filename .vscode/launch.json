{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch TowerDefendEditor (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Binaries/Win64/TowerDefendEditor.exe",
            "args": [
                "${workspaceFolder}/TowerDefend.uproject",
                "-log",
                "-windowed",
                "-ResX=1280",
                "-ResY=720"
            ],
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "visualizerFile": "${workspaceFolder}/TowerDefend.natvis",
            "sourceFileMap": {}
        },
        {
            "name": "Attach to TowerDefendEditor",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "visualizerFile": "${workspaceFolder}/TowerDefend.natvis",
            "sourceFileMap": {}
        }
    ]
}